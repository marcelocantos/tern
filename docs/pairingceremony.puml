@startuml PairingCeremony
!theme plain
skinparam backgroundColor white
skinparam state {
  BackgroundColor #f8f8f8
  BorderColor #888
}

title PairingCeremony

state "server" as B {
  [*] --> B_Idle
  B_Idle --> B_GenerateToken : recv pair_begin\ngenerate_token
  B_GenerateToken --> B_RegisterRelay : token created\nregister_relay
  B_RegisterRelay --> B_WaitingForClient : relay registered
  B_WaitingForClient --> B_DeriveSecret : recv pair_hello\n[token_valid]\nderive_secret
  B_WaitingForClient --> B_Idle : recv pair_hello\n[token_invalid]
  B_DeriveSecret --> B_SendAck : ECDH complete
  B_SendAck --> B_WaitingForCode : signal code display
  B_WaitingForCode --> B_ValidateCode : recv code_submit
  B_ValidateCode --> B_StorePaired : check code\n[code_correct]
  B_ValidateCode --> B_Idle : check code\n[code_wrong]
  B_StorePaired --> B_Paired : finalise\nstore_device
  B_Paired --> B_AuthCheck : recv auth_request
  B_AuthCheck --> B_SessionActive : verify\n[device_known]\nverify_device
  B_AuthCheck --> B_Idle : verify\n[device_unknown]
  B_SessionActive --> B_Paired : disconnect
}

state "ios" as C {
  [*] --> C_Idle
  C_Idle --> C_ScanQR : user scans QR
  C_ScanQR --> C_ConnectRelay : QR parsed
  C_ConnectRelay --> C_GenKeyPair : relay connected
  C_GenKeyPair --> C_WaitAck : key pair generated\nsend_pair_hello
  C_WaitAck --> C_E2EReady : recv pair_hello_ack\nderive_secret
  C_E2EReady --> C_ShowCode : recv pair_confirm
  C_ShowCode --> C_WaitPairComplete : code displayed
  C_WaitPairComplete --> C_Paired : recv pair_complete\nstore_secret
  C_Paired --> C_Reconnect : app launch
  C_Reconnect --> C_SendAuth : relay connected
  C_SendAuth --> C_SessionActive : recv auth_ok
  C_SessionActive --> C_Paired : disconnect
}

state "cli" as R {
  [*] --> R_Idle
  R_Idle --> R_GetKey : cli --init
  R_GetKey --> R_BeginPair : key stored
  R_BeginPair --> R_ShowQR : recv token_response
  R_ShowQR --> R_PromptCode : recv waiting_for_code
  R_PromptCode --> R_SubmitCode : user enters code
  R_SubmitCode --> R_Done : recv pair_status
}

' === Cross-actor interactions ===

B_RegisterRelay -[#888,dashed]-> R_BeginPair : token_response\n{token, instance_id}
B_DeriveSecret -[#888,dashed]-> C_WaitAck : pair_hello_ack\n{pubkey}
B_SendAck -[#888,dashed]-> C_E2EReady : pair_confirm
B_SendAck -[#888,dashed]-> R_ShowQR : waiting_for_code
B_StorePaired -[#888,dashed]-> C_WaitPairComplete : pair_complete\n{key, secret}
B_StorePaired -[#888,dashed]-> R_SubmitCode : pair_status\n{status}
B_AuthCheck -[#888,dashed]-> C_SendAuth : auth_ok
C_GenKeyPair -[#888,dashed]-> B_WaitingForClient : pair_hello\n{token, pubkey}
C_Reconnect -[#888,dashed]-> B_Paired : auth_request\n{key, device_id, secret, nonce}
R_GetKey -[#888,dashed]-> B_Idle : pair_begin
R_PromptCode -[#888,dashed]-> B_WaitingForCode : code_submit\n{code}

@enduml
